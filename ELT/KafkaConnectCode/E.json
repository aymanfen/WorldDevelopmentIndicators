{
  "name": "csv-source",
  "config": {
    "connector.class": "com.github.jcustenborder.kafka.connect.spooldir.SpoolDirCsvSourceConnector",
    "tasks.max": "1",
    "topic": "TestTopic",
    "input.path": "/data",
    "finished.path": "/data/finished",
    "error.path": "/data/error",
    "input.file.pattern": ".*\\.csv",
    "schema.generation.enabled": "true"
  }
}
